# Copy this file to .env and fill in real values.
# Never commit .env — it's already in .gitignore.

# --- Database ---
# Local dev (SQLite): file:./dev.db
# Production: a hosted Postgres URL (Vercel Postgres, Supabase, Neon, etc.)
# If you switch to Postgres, also change `provider` in prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# --- Subdomain routing (optional) ---
# Once you own a domain for the platform itself, set this to enable
# per-business subdomains (e.g. "teetogreen.yourdomain.com/book" instead of
# "yourdomain.com/teetogreen/book"). Leave blank to keep using path-based
# URLs only — everything works either way. See README "Subdomain routing".
NEXT_PUBLIC_ROOT_DOMAIN=""

# --- Square (optional second payment provider — each business picks Stripe or Square) ---
# Create an app at https://developer.squareup.com/apps
# Authorized redirect URI to add there: http://localhost:3000/api/square/callback
SQUARE_APPLICATION_ID=""
SQUARE_APPLICATION_SECRET=""
# "sandbox" while developing, "production" when you flip live
SQUARE_ENVIRONMENT="sandbox"
# From the webhook subscription you create in the Square Developer Dashboard
# (Webhooks → Subscribe to Events → "payment.updated"), pointed at
# <your-domain>/api/square/webhook
SQUARE_WEBHOOK_SIGNATURE_KEY=""

# --- Google OAuth (used for both login AND calendar sync) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs to add there:
#   http://localhost:3000/api/auth/callback/google       (login)
#   http://localhost:3000/api/calendar/callback           (calendar connect)
# Enable the "Google Calendar API" in the same Google Cloud project.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/calendar/callback"

# --- Outlook/Microsoft 365 (optional second calendar provider — each business picks Google or Outlook) ---
# Register an app at https://portal.azure.com -> Azure Active Directory -> App registrations
# Redirect URI to add there (as a "Web" platform redirect): http://localhost:3000/api/calendar/outlook/callback
# Under "Certificates & secrets", create a client secret and use it below.
# Supported account types: choose "Accounts in any organizational directory and personal Microsoft accounts"
OUTLOOK_CLIENT_ID=""
OUTLOOK_CLIENT_SECRET=""
OUTLOOK_CALENDAR_REDIRECT_URI="http://localhost:3000/api/calendar/outlook/callback"

# --- Resend (booking notification emails to the instructor) ---
# Sign up at https://resend.com, get an API key from the dashboard
RESEND_API_KEY=""
# The "from" address for notification emails — must be on a domain you've
# verified in Resend. While testing, you can use their shared test domain
# (onboarding@resend.dev) which works without verifying anything.
RESEND_FROM_EMAIL="onboarding@resend.dev"

# --- Calendar sync automation ---
# A random secret used to authorize scheduled sync calls (see README "Two-way calendar sync").
# Generate one with: openssl rand -hex 24
CRON_SECRET=""

# --- Stripe ---
# Get keys at https://dashboard.stripe.com/apikeys (use test keys while developing)
STRIPE_SECRET_KEY=""
# After deploying, create a webhook endpoint at https://dashboard.stripe.com/webhooks
# pointing to <your-domain>/api/stripe/webhook, listening for "checkout.session.completed".
# For local testing, use the Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=""
